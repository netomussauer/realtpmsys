# ── Banco de dados ────────────────────────────────────────────────────────────
DB_URL=postgresql://postgres:postgres@localhost:5432/realtpmsys?sslmode=disable
DB_URL_TEST=postgresql://postgres:postgres@localhost:5432/realtpmsys_test?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# ── Autenticação JWT ──────────────────────────────────────────────────────────
JWT_SECRET=troque_para_chave_secreta_forte_256bits
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=7

# ── Servidor ──────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_READ_TIMEOUT_SECONDS=30
APP_WRITE_TIMEOUT_SECONDS=30

# ── Observabilidade ───────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=realtpmsys
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info
